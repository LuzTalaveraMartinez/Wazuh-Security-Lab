<group name="local,syslog,sshd,sudo,">

  <!-- Regla de ejemplo original para SSH -->
  <rule id="100001" level="5">
    <if_sid>5716</if_sid>
    <srcip>1.1.1.1</srcip>
    <description>sshd: authentication failed from IP 1.1.1.1.</description>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>

  <!-- TU NUEVA REGLA PERSONALIZADA (ID cambiado a 100002) -->
  <rule id="100002" level="10">
    <if_sid>5402</if_sid>
    <description>ALERTA CRÍTICA: El usuario $(srcuser) ha escalado a ROOT exitosamente.</description>
    <group>pci_dss_10.2.5,gpg13_7.1,gdpr_IV_32.2,</group>
  </rule>

</group>
